# ── LLM Provider ─────────────────────────────────────────────────────
# OpenAI (default) — used by all agents
OPENAI_API_KEY=sk-...

# Optional: Use a different model (default: gpt-4o)
# OPENAI_MODEL_NAME=gpt-4o-mini

# Optional: Use Anthropic instead
# ANTHROPIC_API_KEY=sk-ant-...

# ── Search Tools ─────────────────────────────────────────────────────
# Required for SerperDevTool (web search for agents)
# Get your key at https://serper.dev/
SERPER_API_KEY=YOUR_SERPER_KEY_HERE

# ── Optional: Additional Tool Keys ──────────────────────────────────
# For BraveSearchTool (alternative to Serper)
# BRAVE_API_KEY=...

# For Firecrawl tools (advanced web scraping)
# FIRECRAWL_API_KEY=...
